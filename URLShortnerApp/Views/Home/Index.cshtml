@model URLShortnerApp.DataAccess.Models.URLModel

@{
    ViewData["Title"] = "Home Page";
}

<form method="post">
    <div class="row p-3 border">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-12 border-bottom">
            <h2 class="text-primary">Enter your URL and get it shortened</h2>
        </div>
        <div class="col-8 pt-4">
            <div class="form-group row">
                <div class="col-9">
                    <input asp-for="Id" />
                    <input asp-for="URL" class="form-control" />
                </div>
                <div class="col-3">
                    <button class="btn btn-primary" asp-controller="URL" asp-action="PostURL">Shorten URL</button>
                </div>
            </div>
        </div>
    </div>
</form>
